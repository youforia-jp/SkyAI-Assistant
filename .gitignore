# =============================================================================
# SkyAI — Root .gitignore
# Covers: SkyAI-Mod-1.21.10 (Fabric/Gradle) + SkyAI-Backend (Python/FastAPI)
# =============================================================================

# ---------------------------------------------------------------------------
# 🔐 SECRETS — NEVER COMMIT
# ---------------------------------------------------------------------------
api_key.txt
gemini_key.txt
*_key.txt
*.key
.env
.env.*

# ---------------------------------------------------------------------------
# 🗄️ RUNTIME DATA & AI CACHES — NEVER COMMIT
# ---------------------------------------------------------------------------
omni_context.json
omni_config.json
data/
cache_*.json
*_cache.json
*.session.json

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
wheels/
pip-wheel-metadata/
*.so
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Java / Fabric / Gradle
# ---------------------------------------------------------------------------
.gradle/
build/
out/
classes/
*.class
*.jar

# Fabric loom runtime directories
run/
remappedSrc/

# ---------------------------------------------------------------------------
# IDE & Editor
# ---------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.classpath
.project
*.launch
bin/

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
*.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Logs & Crash reports
# ---------------------------------------------------------------------------
hs_err_*.log
replay_*.log
*.hprof
*.jfr
logs/
